rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── YARDIMCI FONKSİYONLAR ───
    function isAdmin() {
      return request.auth != null &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isAdminOrEditor() {
      return request.auth != null &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'editor']);
    }

    match /users/{userId} {
      allow get: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'editor']
      );
      allow list: if request.auth != null && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'editor']);

      // KVKK KORUMASI: Normal kullanıcılar hesap açarken kendilerine yetki veremez
      allow create: if request.auth != null && request.auth.uid == userId &&
                    (!('isAdmin' in request.resource.data) || request.resource.data.isAdmin == false) &&
                    (!('role' in request.resource.data) || request.resource.data.role == 'user');

      // YETKİ YÜKSELTME ENGELİ (Privilege Escalation Prevention):
      allow update: if request.auth != null && (
        // 1. Kullanıcı kendisini güncelliyorsa, role ve isAdmin alanlarını DEĞİŞTİREMEZ
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'role'])) ||
        // 2. İşlemi yapan zaten önceden yetkili bir admin ise serbest
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );

      allow delete: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    match /feedbacks/{feedbackId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'editor']);
    }

    match /app_messages/{msgId} {
      allow read: if true;
      allow create, delete: if request.auth != null
                    && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'editor']);
      allow update: if request.auth != null && (
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'editor'])
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['openedCount']))
      );
    }

    match /deleted_accounts_log/{logId} {
      allow create: if request.auth != null;
      allow read, delete, update: if request.auth != null
                    && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    match /mini_apps/{appId} {
      allow read: if true;
      allow create, delete, update: if request.auth != null
                    && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'editor']);
    }

    // ─── ETKİNLİK MODÜLÜ KURALLARI ───
    match /events/{eventId} {
      // Tek doküman okuma ve listeleme: published etkinlikler herkese açık, adminler tümünü okuyabilir
      allow read: if resource.data.status == 'published' ||
                  (request.auth != null &&
                   (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
                    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'editor']));

      // Oluşturma: sadece admin/editor
      allow create: if request.auth != null &&
                    (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'editor']);

      // Güncelleme: sadece admin/editor
      allow update: if request.auth != null &&
                    (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'editor']);

      // Silme: sadece admin
      allow delete: if request.auth != null &&
                    (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    match /categories/{catId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'editor']
      );
    }

    // ─── TİYATRO UYGULAMASI KURALLARI ───
    match /tiyatro_videos/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /tiyatro_settings/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /constants/{constId} {
      allow read: if true;
      allow write: if request.auth != null
                    && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    match /app_config/{configId} {
      allow read: if true;
      allow write: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'editor']
      );
    }

    // ─── SAYFA YAPILANDIRMASI (Sayfa Tasarlayıcı) ───
    match /page_configs/{pageId} {
      // Tüm giriş yapmış kullanıcılar okuyabilir (mobil uygulama için)
      allow read: if request.auth != null;
      // Sadece admin/editor yazabilir
      allow write: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'editor']
      );
    }

    match /app_usage_stats/{docId} {
      allow read: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'editor']
      );
      allow create, update: if request.auth != null;
    }

    // Masal Atölyesi kullanici kota takibi
    match /masal_users/{email} {
      allow read, write: if true;
    }

    // Masal Atölyesi kullanici gorusleri
    match /masal_feedback/{feedbackId} {
      allow create: if true;
      allow read: if true;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
